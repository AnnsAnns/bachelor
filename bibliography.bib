@inproceedings{teaching_embedded_systems_2024,
author = {Doropoulou, Dimitra and Angelopoulos, Vasileios and Amanatidis, Petros and Lagkas, Thomas and Karampatzakis, Dimitris},
title = {Teaching Embedded Systems and IoT at the University using MicroPython and Raspeberry Pi Pico},
year = {2024},
isbn = {9798400716263},
publisher = {Association for Computing Machinery},
address = {New York, NY, USA},
url = {https://doi.org/10.1145/3635059.3635079},
doi = {10.1145/3635059.3635079},
abstract = {In this paper we present a set of laboratory lessons tailored for students enrolled in Computer Science university programs with the focal point being the utilization of Python in 32-bit microchips. These lessons prepared for an Embedded Systems course and introduces MicroPython programming language in Raspberry Pico microcontroller. In the context of these lessons, an introduction to the concept of the Internet of Things (IoT) has been made. The lessons were designed using pedagogical methods such as physical computing, wherein students write code to engage with the tangible realm via specialized hardware. Additionally, the pedagogical approach incorporates Project-based Learning (PBL), a didactic strategy where educational pursuits are structured around the design, creation, and evaluation of the digital object. Through these laboratory exercises, the students gain new knowledge and at the same time use it to implement a semester assignment in groups.},
booktitle = {Proceedings of the 27th Pan-Hellenic Conference on Progress in Computing and Informatics},
pages = {130–135},
numpages = {6},
keywords = {Education, Embedded systems, Hands-on, Raspberry pi pico},
location = {Lamia, Greece},
series = {PCI '23}
}

